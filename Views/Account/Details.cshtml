@model SpinaBets.Models.Account
@{
    ViewData["Title"] = "Account Details";
}

<div class="container mt-4">

    <div class="card shadow mb-4">

        <div class="card-header bg-dark text-white">
            <h3>@Model.AccountType Account</h3>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">

                    <p>
                        <strong>Account Number:</strong>
                        <br />
                        @Model.AccountNumber
                    </p>

                    <p>
                        <strong>Balance:</strong>
                        <br />
                        R @Model.Balance
                    </p>

                    <p>
                        <strong>Status:</strong>
                        <br />

                        @if (Model.IsClosed)
                        {
                            <span class="badge bg-danger">
                                Closed
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                Open
                            </span>
                        }
                    </p>

                    <p>
                        <strong>Created:</strong>
                        <br />
                        @Model.CreatedDate.ToString("dd MMM yyyy")
                    </p>

                </div>

            </div>

            <hr />
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (!Model.IsClosed)
            {
                <form asp-action="Close"
                      method="post">

                    <input type="hidden"
                           name="id"
                           value="@Model.AccountId" />

                    <button type="submit"
                            class="btn btn-danger">
                        Close Account
                    </button>

                </form>
            }
            else
            {
                <form asp-action="Reopen"
                      method="post">

                    <input type="hidden"
                           name="id"
                           value="@Model.AccountId" />

                    <button type="submit"
                            class="btn btn-success">
                        Reopen Account
                    </button>

                </form>
            }

        </div>
    </div>

    <!-- TRANSACTIONS -->

    <div class="card shadow">

        <div class="card-header d-flex justify-content-between align-items-center">

            <h4>Transactions</h4>

            @if (!Model.IsClosed)
            {
                <a asp-controller="Transactions"
                   asp-action="Create"
                   asp-route-accountId="@Model.AccountId"
                   class="btn btn-primary">
                    Add Transaction
                </a>
            }

        </div>

        <div class="card-body">

            @if (Model.Transactions == null ||
                 !Model.Transactions.Any())
            {
                <div class="alert alert-info">
                    No transactions found.
                </div>
            }
            else
            {
                <table class="table table-striped">

                    <thead>

                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var transaction in Model.Transactions)
                        {
                            <tr>

                                <td>
                                    @transaction.TransactionDate
                                    .ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @transaction.TransactionType
                                </td>

                                <td>
                                    R @transaction.Amount
                                </td>
                                <td>
                                    <a asp-action="Edit"
                                        asp-controller="Transactions"
                                       asp-route-id="@transaction.TransactionId"
                                       class="btn btn-primary btn-sm">
                                        Edit
                                    </a>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }

        </div>

    </div>

</div>
