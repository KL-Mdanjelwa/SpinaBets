@{
    ViewData["Title"] = "About Spina Bets";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">
            About Spina Bets
        </h1>

        <p class="lead">
            More than betting. A smarter way to experience sport.
        </p>
    </div>

    <div class="card shadow-lg border-0 p-5">

        <h3>Our Story</h3>

        <p>
            Spina Bets was founded with a simple vision: to create a modern,
            secure and exciting sports betting experience that places users
            first.
        </p>

        <p>
            Inspired by the growing popularity of digital entertainment and
            sports across Africa, our fictional company was established to
            combine innovative technology with responsible betting practices.
            Every feature on the platform has been designed to provide a fast,
            transparent and enjoyable experience for both new and experienced
            bettors.
        </p>

        <hr />

        <h3>What We Offer</h3>

        <div class="row mt-4">

            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">

                        <h5>Sports Betting</h5>

                        <p>
                            Browse a variety of sporting events,
                            compare competitive odds,
                            and place bets confidently.
                        </p>

                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">

                        <h5>Secure Wallets</h5>

                        <p>
                            Create betting accounts,
                            manage deposits,
                            withdrawals,
                            and track balances in real time.
                        </p>

                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">

                        <h5>Transparent Results</h5>

                        <p>
                            Administrators manage sporting fixtures,
                            settle results fairly,
                            and ensure accurate payouts.
                        </p>

                    </div>
                </div>
            </div>

        </div>

        <hr class="my-5" />

        <h3>Our Mission</h3>

        <p>
            To provide an engaging,
            secure,
            responsible,
            and technology-driven betting platform that delivers
            exceptional customer experiences while promoting fair play,
            integrity,
            and responsible gambling.
        </p>

    </div>

</div>