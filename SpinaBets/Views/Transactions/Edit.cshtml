@model SpinaBets.Models.Transaction

@{
    ViewData["Title"] = "Edit Transaction";
}

<div class="container mt-4">

    <h2>Edit Transaction</h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="TransactionId" />
        <input type="hidden" asp-for="AccountId" />

        <div class="mb-3">

            <label>Type</label>

            <select asp-for="TransactionType" class="form-control">

                <option value="Deposit">Deposit</option>
                <option value="Withdrawal">Withdrawal</option>

            </select>

        </div>

        <div class="mb-3">

            <label>Amount</label>
            <input asp-for="Amount" class="form-control" />

        </div>

        <div class="mb-3">

            <label>Date</label>
            <input asp-for="TransactionDate" type="date" class="form-control" />

        </div>

        <div class="mb-3">

            <label>Reference</label>
            <input asp-for="Reference" class="form-control" />

        </div>

        <button class="btn btn-primary">
            Save Changes
        </button>

    </form>

</div>