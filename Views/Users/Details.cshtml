@model SpinaBets.ViewModels.UserViewModel

<h2>User Details</h2>

<div class="card p-3">

    <p><strong>Name:</strong> @Model.FirstName @Model.Surname</p>

    <p><strong>Email:</strong> @Model.Email</p>

    <p><strong>Phone:</strong> @Model.PhoneNumber</p>

    <p><strong>ID Number:</strong> @Model.IDNumber</p>

    <p><strong>Roles:</strong> @string.Join(", ", Model.Roles)</p>

    <p><strong>Created:</strong> @Model.CreatedDate</p>

</div>