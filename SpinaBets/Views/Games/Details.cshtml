@model SpinaBets.Models.Game

<h2>Game Details</h2>

<p><strong>Sport:</strong> @Model.Sport?.Name</p>
<p><strong>Match:</strong> @Model.HomeTeam vs @Model.AwayTeam</p>
<p><strong>Start:</strong> @Model.StartTime</p>
<p><strong>Status:</strong> @Model.Status</p>
<p><strong>Result:</strong> @Model.Result</p>